  "weight_estimation": {
    "comment": "APLS-derived. <1 month requires user input. >12 years requires user input.",
    "bands": [
      { "max_months": 12, "formula": "months_plus_9_over_2" },
      { "max_years":  6,  "formula": "years_times_2_plus_8" },
      { "max_years":  12, "formula": "years_times_7_minus_5_over_2" }
    ]
  },

  "ett_rules": {
    "comment": "Neonatal weight-based, then 6-month / <1y fixed at 4.0, then formula 4.5 + age/4 per v1 formularium. Round result both up and down to nearest 0.5.",
    "neonatal_weight_table": [
      { "max_kg": 1, "size": 2.5 },
      { "max_kg": 2, "size": 3.0 },
      { "max_kg": 3, "size": 3.5 }
    ],
    "infant_under_1y_size": 4.0,
    "child_formula": { "base": 4.5, "divisor": 4 },
    "round_to_nearest": 0.5
  },

  "lma_table_comment": "Bands overlap intentionally per v1 formularium. A patient in an overlap region shows both sizes; a patient in a single band additionally shows the next size up. min/max are INCLUSIVE on both ends.",
