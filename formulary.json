        { "name": "Atropine",                   "type": "linear",      "factor": 20,   "unit": "µg", "route": "IV" },
        { "name": "Adenosine (1st dose)",       "type": "linear_max",  "factor": 0.1,  "max": 6,  "unit": "mg", "route": "IV" },
